kind: ImageSetConfiguration
apiVersion: mirror.openshift.io/v2alpha1
mirror:
  platform:
    channels:
    - name: stable-{{ openshift_major_version }}
      minVersion: {{ openshift_version }}
      maxVersion: {{ openshift_version }}
    graph: true 
  operators:
    - catalog: registry.redhat.io/redhat/redhat-operator-index:v{{ openshift_major_version }} 
      packages: 
{% for op in mirror_operators %}
       - name: {{ op }}
{% endfor %}
  additionalImages: 
   - name: registry.redhat.io/ubi8/ubi:latest
