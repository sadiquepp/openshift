# ── Required ──────────────────────────────────────────────────────
ssh_public_key = "ssh-rsa AAAAB3Nza..."

# ── Naming ────────────────────────────────────────────────────────
prefix_for_name               = "myproject"
openshift_base_domain         = "example.com"
openshift_cluster_name_suffix = "xt1"

# ── Region ────────────────────────────────────────────────────────
aws_region = "ap-southeast-1"

# ── Disconnected VPC ─────────────────────────────────────────────
disconnected_vpc_cidr    = "172.16.0.0/16"
disconnected_subnet_cidrs = ["172.16.1.0/24", "172.16.2.0/24", "172.16.3.0/24"]

# ── Egress VPC ───────────────────────────────────────────────────
egress_vpc_cidr              = "172.17.0.0/16"
egress_public_subnet_cidrs   = ["172.17.1.0/24", "172.17.2.0/24", "172.17.3.0/24"]
egress_private_subnet_cidrs  = ["172.17.4.0/24", "172.17.5.0/24", "172.17.6.0/24"]

# ── VPC Endpoints ────────────────────────────────────────────────
# Regional endpoints: com.amazonaws.<region>.<service>
interface_endpoint_services = ["ec2", "sts", "elasticloadbalancing", "ecr.api", "ecr.dkr"]
# Global cross-region endpoints: com.amazonaws.<service>  (no region prefix)
global_endpoint_services    = ["iam", "route53"]

# ── Cross-region endpoints (us-east-1) ──────────────────────────
# The Tagging API endpoint is only available in us-east-1.
# Set to true to create a us-east-1 VPC with peering and a
# Route53 private zone override so the disconnected VPC can
# reach tagging.us-east-1.amazonaws.com privately.
create_cross_region_endpoints  = false
cross_region_endpoint_services = ["tagging"]
cross_region_vpc_cidr          = "10.99.0.0/24"
cross_region_subnet_cidr       = "10.99.0.0/26"

# ── UPI Node IPs (host number within each subnet) ───────────────
# bootstrap, master0, worker1, infra1 → subnet A (AZ1)
# master1, worker2, infra2             → subnet B (AZ2)
# master2, worker3, infra3             → subnet C (AZ3)
# upi_node_host_numbers = {
#   bootstrap = 99
#   master0   = 100
#   master1   = 100
#   master2   = 100
#   worker1   = 110
#   worker2   = 110
#   worker3   = 110
#   infra1    = 120
#   infra2    = 120
#   infra3    = 120
# }

# ── Bastion EC2 ──────────────────────────────────────────────────
ssh_private_key_path    = "~/.ssh/id_rsa"
installer_ami           = "ami-04698733964af06d5"
installer_instance_type = "c6i.large"
installer_disk_size     = 100

# ── Self-Managed HCP (Hosted Control Planes) ─────────────────────
# Uncomment and populate to enable HCP cluster deployment.
# Each suffix creates OIDC infrastructure, IAM roles (7 operator +
# 1 worker per suffix), Route53 zones, and PrivateLink credentials.
# HCP clusters use the same disconnected VPC (private endpoint only).
#
# hcp_cluster_suffixes = ["hcp1"]
