apiVersion: v1
baseDomain: {{ openshift_base_domain }}
credentialsMode: Manual
compute:
- architecture: amd64
  hyperthreading: Enabled
  name: worker
  platform: {}
  replicas: 3
controlPlane:
  architecture: amd64
  hyperthreading: Enabled
  name: master
  platform: {}
  replicas: 3
metadata:
  creationTimestamp: null
  name: {{ openshift_cluster_name }}
networking:
  clusterNetwork:
  - cidr: 10.128.0.0/14
    hostPrefix: 23
  machineNetwork:
  - cidr: {{ connected_vpc_cidr }}
  networkType: OVNKubernetes
  serviceNetwork:
  - 172.30.0.0/16
platform:
  gcp:
    projectID: {{ gcp_project_id }}
    region: {{ gcp_region }}
    network: {{ connected_vpc_name }}
    controlPlaneSubnet: {{ control_plane_subnet_name }}
    computeSubnet: {{ compute_subnet_name }}
publish: Internal
pullSecret: '{{ pull_secret }}'
sshKey: |
  {{ ssh_public_key_for_vm_and_openshift_node }}
