#!/bin/bash
set -euo pipefail

echo "=== Applying Let's Encrypt certificates ==="
echo "API:     api.{{ openshift_cluster_name }}.{{ openshift_base_domain }}"
echo "Ingress: *.apps.{{ openshift_cluster_name }}.{{ openshift_base_domain }}"
echo ""

oc apply -f letsencrypt-api-cert-secret.yaml
oc apply -f letsencrypt-ingress-cert-secret.yaml

echo ""
echo "=== Patching APIServer to use Let's Encrypt certificate ==="
oc patch apiserver cluster --type=merge -p '{
  "spec": {
    "servingCerts": {
      "namedCertificates": [
        {
          "names": ["api.{{ openshift_cluster_name }}.{{ openshift_base_domain }}"],
          "servingCertificate": {
            "name": "letsencrypt-api-cert"
          }
        }
      ]
    }
  }
}'

echo ""
echo "=== Patching IngressController to use Let's Encrypt certificate ==="
oc patch ingresscontroller default -n openshift-ingress-operator --type=merge -p '{
  "spec": {
    "defaultCertificate": {
      "name": "letsencrypt-ingress-cert"
    }
  }
}'

echo ""
echo "=== Done. API server pods will restart (takes a few minutes). ==="
echo "Verify with: curl -v https://api.{{ openshift_cluster_name }}.{{ openshift_base_domain }}:6443 2>&1 | grep issuer"
